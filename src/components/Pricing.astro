---
// src/components/Pricing.astro
---

<section id="pricing" class="py-24 bg-white sm:py-32">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="mx-auto max-w-4xl text-center">
      <h2 class="text-base font-semibold leading-7 text-emerald-500">Pricing</h2>
      <p class="mt-2 text-4xl font-bold tracking-tight text-slate-900 sm:text-5xl">Transparent pricing for businesses of all sizes</p>
      <p class="mx-auto mt-6 max-w-2xl text-center text-lg leading-8 text-slate-600">
        Start with a <span class="font-bold text-[#0B2B5E]">14-Day Free Trial</span> on any tier. No credit card required. Cancel anytime.
      </p>
    </div>

    <div class="isolate mx-auto mt-16 grid max-w-md grid-cols-1 gap-y-8 sm:mt-20 lg:mx-0 lg:max-w-none lg:grid-cols-3 lg:gap-x-8 lg:gap-y-0">
      
      <!-- Basic Plan -->
      <div class="rounded-3xl p-8 ring-1 ring-slate-200 xl:p-10 flex flex-col justify-between">
        <div>
          <h3 class="text-lg font-semibold leading-8 text-slate-900">Basic</h3>
          <p class="mt-4 text-sm leading-6 text-slate-600">Perfect for single-store startups getting off the ground.</p>
          <p class="mt-6 flex items-baseline gap-x-1">
            <span class="text-4xl font-bold tracking-tight text-slate-900">$15</span>
            <span class="text-sm font-semibold leading-6 text-slate-600">/month</span>
          </p>
          <ul role="list" class="mt-8 space-y-3 text-sm leading-6 text-slate-600">
            <li class="flex gap-x-3"><span class="text-emerald-500">✓</span> 1 Branch / Location</li>
            <li class="flex gap-x-3"><span class="text-emerald-500">✓</span> Up to 3 User Accounts</li>
            <li class="flex gap-x-3"><span class="text-emerald-500">✓</span> Standard POS Terminal</li>
            <li class="flex gap-x-3"><span class="text-emerald-500">✓</span> Basic Reporting</li>
          </ul>
        </div>
        <a href="https://dashboard.vendorapos.app/register" class="mt-8 block rounded-md py-2 px-3 text-center text-sm font-semibold leading-6 text-emerald-600 ring-1 ring-inset ring-emerald-200 hover:ring-emerald-300 hover:bg-emerald-50 transition-colors">Start Free Trial</a>
      </div>

      <!-- Pro Plan (Highlighted) -->
      <div class="rounded-3xl p-8 ring-2 ring-emerald-500 xl:p-10 relative flex flex-col justify-between bg-slate-50 shadow-xl">
        <div class="absolute top-0 -translate-y-1/2 left-1/2 -translate-x-1/2">
          <span class="bg-emerald-500 text-white text-xs font-bold uppercase tracking-wider py-1 px-3 rounded-full">Most Popular</span>
        </div>
        <div>
          <h3 class="text-lg font-semibold leading-8 text-[#0B2B5E]">Pro</h3>
          <p class="mt-4 text-sm leading-6 text-slate-600">For growing retail stores that need multi-location management.</p>
          <p class="mt-6 flex items-baseline gap-x-1">
            <span class="text-4xl font-bold tracking-tight text-slate-900">$30</span>
            <span class="text-sm font-semibold leading-6 text-slate-600">/month</span>
          </p>
          <ul role="list" class="mt-8 space-y-3 text-sm leading-6 text-slate-600">
            <li class="flex gap-x-3"><span class="text-emerald-500">✓</span> Up to 3 Branches</li>
            <li class="flex gap-x-3"><span class="text-emerald-500">✓</span> Up to 10 User Accounts</li>
            <li class="flex gap-x-3"><span class="text-emerald-500">✓</span> Advanced Inventory Control</li>
            <li class="flex gap-x-3"><span class="text-emerald-500">✓</span> Multi-store syncing</li>
          </ul>
        </div>
        <a href="https://dashboard.vendorapos.app/register" target="_blank" class="mt-8 block rounded-md bg-emerald-500 py-2 px-3 text-center text-sm font-semibold leading-6 text-white shadow-sm hover:bg-emerald-400 transition-colors">Start Free Trial</a>
      </div>

      <!-- Enterprise Plan -->
      <div class="rounded-3xl p-8 ring-1 ring-slate-200 xl:p-10 flex flex-col justify-between">
        <div>
          <h3 class="text-lg font-semibold leading-8 text-slate-900">Enterprise</h3>
          <p class="mt-4 text-sm leading-6 text-slate-600">Dedicated resources and unlimited scaling for massive operations.</p>
          <p class="mt-6 flex items-baseline gap-x-1">
            <span class="text-4xl font-bold tracking-tight text-slate-900">Custom</span>
          </p>
          <ul role="list" class="mt-8 space-y-3 text-sm leading-6 text-slate-600">
            <li class="flex gap-x-3"><span class="text-emerald-500">✓</span> Unlimited Branches</li>
            <li class="flex gap-x-3"><span class="text-emerald-500">✓</span> Unlimited Users</li>
            <li class="flex gap-x-3"><span class="text-emerald-500">✓</span> God-View Dashboard</li>
            <li class="flex gap-x-3"><span class="text-emerald-500">✓</span> 24/7 Priority Support</li>
          </ul>
        </div>
        <a href="/contact" class="mt-8 block rounded-md py-2 px-3 text-center text-sm font-semibold leading-6 text-slate-600 ring-1 ring-inset ring-slate-200 hover:ring-slate-300 hover:bg-slate-50 transition-colors">Contact Sales</a>
      </div>

    </div>
  </div>
</section>