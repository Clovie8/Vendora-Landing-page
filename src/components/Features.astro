---
// src/components/Features.astro
const features = [
  {
    title: 'Smart Inventory Management',
    description: 'Never run out of stock. Get real-time alerts, automate purchase orders, and track SKU movements across all locations.',
    icon: `<svg class="w-6 h-6 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M20.25 7.151V16.85a3 3 0 01-1.31 2.476l-5.69 3.282a3 3 0 01-3.5 0l-5.69-3.282A3 3 0 012.75 16.85V7.151a3 3 0 011.31-2.476l5.69-3.282a3 3 0 013.5 0l5.69 3.282a3 3 0 011.31 2.476z" /><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m-7.5-10.5l7.5 4.5 7.5-4.5" /></svg>`
  },
  {
    title: 'Multi-Branch Support',
    description: 'Manage a single store or a massive retail chain. Sync data instantly and control all your branches from one centralized HQ.',
    icon: `<svg class="w-6 h-6 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 21v-7.5a.75.75 0 01.75-.75h3a.75.75 0 01.75.75V21m-4.5 0H2.36m11.14 0H18m0 0h3.64m-1.39 0V9.809a.75.75 0 00-.22-.53l-10.5-10.5a.75.75 0 00-1.06 0l-10.5 10.5a.75.75 0 00-.22.53V21M18 21v-7.5a.75.75 0 00-.75-.75h-3a.75.75 0 00-.75.75V21" /></svg>`
  },
  {
    title: 'Digital Receipts & Invoicing',
    description: 'Generate VAT-ready invoices on the fly. Send permanent digital receipts via email or SMS, keeping your business compliant and eco-friendly.',
    icon: `<svg class="w-6 h-6 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" /></svg>`
  },
  {
    title: 'God-View Analytics',
    description: 'Make data-driven decisions with advanced reporting. Visualize sales trends, identify best-selling items, and monitor employee performance.',
    icon: `<svg class="w-6 h-6 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z" /></svg>`
  }
];
---

<section id="features" class="bg-white pb-24 pt-48 sm:pb-32 sm:pt-64 lg:pt-80">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="mx-auto max-w-2xl lg:text-center">
      <h2 class="text-base font-semibold leading-7 text-emerald-500">Why Vendora?</h2>
      <p class="mt-2 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">Everything you need to scale your sales</p>
      <p class="mt-6 text-lg leading-8 text-slate-600">Ditch the spreadsheets. Vendora provides an enterprise-grade toolkit that simplifies complex retail and wholesale operations into a few clicks.</p>
    </div>
    <div class="mx-auto mt-16 max-w-2xl sm:mt-20 lg:mt-24 lg:max-w-none">
      <dl class="grid max-w-xl grid-cols-1 gap-x-8 gap-y-16 lg:max-w-none lg:grid-cols-4">
        {features.map((feature) => (
          <div class="flex flex-col bg-slate-50 p-6 rounded-2xl shadow-sm ring-1 ring-slate-100 hover:shadow-md transition-shadow">
            <dt class="flex items-center gap-x-3 text-base font-semibold leading-7 text-slate-900">
              <div class="h-10 w-10 flex items-center justify-center rounded-lg bg-emerald-500/10" set:html={feature.icon} />
              {feature.title}
            </dt>
            <dd class="mt-4 flex flex-auto flex-col text-base leading-7 text-slate-600">
              <p class="flex-auto">{feature.description}</p>
            </dd>
          </div>
        ))}
      </dl>
    </div>
  </div>
</section>