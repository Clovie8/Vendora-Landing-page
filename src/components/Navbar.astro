---
// src/components/Navbar.astro
---

<header class="absolute inset-x-0 top-0 z-50 border-b border-white/10 bg-[#0B2B5E]/90 backdrop-blur-md">
  <nav class="mx-auto flex max-w-7xl items-center justify-between p-4 lg:px-8" aria-label="Global">
    
    <div class="flex lg:flex-1">
      <a href="/" class="-m-1.5 p-1.5 flex items-center gap-2 text-white">
        <span class="sr-only">Vendora</span>
        <img class="h-12 w-auto" src="/Vendora-logo.png" alt="Vendora Logo"/>
        <span class="text-xl font-bold tracking-tight">Vendora</span>
      </a>
    </div>

    <div class="flex lg:hidden">
      <button 
        type="button" 
        id="mobile-menu-btn" 
        class="-m-2.5 inline-flex items-center justify-center rounded-md p-2.5 text-slate-300 hover:text-white transition-colors focus:outline-none" 
        aria-expanded="false"
      >
        <span class="sr-only">Toggle main menu</span>
        
        <svg id="hamburger-icon" class="h-6 w-6 block transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
        </svg>
        
        <svg id="close-icon" class="h-6 w-6 hidden transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <div class="hidden lg:flex items-center gap-8">
      <a href="/" class="text-slate-300 hover:text-white transition-colors">Home</a>
      <a href="/#features" class="text-slate-300 hover:text-white transition-colors">Features</a>
      <a href="/about" class="text-slate-300 hover:text-white transition-colors">About Us</a>
      <a href="/contact" class="text-slate-300 hover:text-white transition-colors">Contact</a>
    </div>

    <div class="hidden lg:flex lg:flex-1 lg:justify-end lg:items-center lg:gap-6">
      <a 
        href="https://dashboard.vendorapos.app/login" 
        target="_blank" 
        class="inline-flex items-center justify-center bg-white/5 border border-white/20 hover:border-white/40 hover:bg-white/10 text-white text-sm font-semibold py-2 px-4 rounded-md transition-all focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white"
      >
        Sign in
      </a>
      <a href="https://dashboard.vendorapos.app/register" target="_blank" class="rounded-md bg-emerald-500 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-emerald-400 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-500 transition-all">
        Start Free Trial
      </a>
    </div>
  </nav>

  <div 
    id="mobile-menu" 
    class="absolute top-full inset-x-0 -z-10 border-t border-white/10 bg-[#0B2B5E] px-6 py-6 space-y-6 shadow-2xl transition-all duration-300 ease-in-out opacity-0 invisible -translate-y-4 pointer-events-none lg:hidden"
  >
    <div class="space-y-3">
      <a href="/" class="block rounded-xl px-4 py-3 text-base font-semibold text-white hover:bg-white/10 transition-colors">Home</a>
      <a href="/#features" class="block rounded-xl px-4 py-3 text-base font-semibold text-white hover:bg-white/10 transition-colors">Features</a>
      <a href="/about" class="block rounded-xl px-4 py-3 text-base font-semibold text-white hover:bg-white/10 transition-colors">About Us</a>
      <a href="/contact" class="block rounded-xl px-4 py-3 text-base font-semibold text-white hover:bg-white/10 transition-colors">Contact</a>
    </div>
    
    <div class="border-t border-white/10 pt-6 space-y-4">
      <a 
        href="https://dashboard.vendorapos.app/login" 
        target="_blank" 
        class="block text-center bg-white/5 border border-white/20 hover:border-white/40 hover:bg-white/10 text-white text-base font-semibold py-3 px-4 rounded-xl transition-all focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white"
      >
        Sign in
      </a>
      <a href="https://dashboard.vendorapos.app/register" target="_blank" class="block w-full rounded-xl bg-emerald-500 px-4 py-3.5 text-center text-base font-bold text-white shadow-md hover:bg-emerald-400 transition-all">
        Start Free Trial
      </a>
    </div>
  </div>
</header>

<script is:inline>
  const menuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const hamburgerIcon = document.getElementById('hamburger-icon');
  const closeIcon = document.getElementById('close-icon');

  function toggleMenu() {
    const isExpanded = menuBtn.getAttribute('aria-expanded') === 'true';
    menuBtn.setAttribute('aria-expanded', !isExpanded);
    
    // Toggle Animation & Visibility states simultaneously
    mobileMenu.classList.toggle('opacity-0');
    mobileMenu.classList.toggle('invisible');
    mobileMenu.classList.toggle('-translate-y-4');
    mobileMenu.classList.toggle('pointer-events-none');
    
    mobileMenu.classList.toggle('opacity-100');
    mobileMenu.classList.toggle('visible');
    mobileMenu.classList.toggle('translate-y-0');
    mobileMenu.classList.toggle('pointer-events-auto');
    
    // Toggle Icon Assets
    hamburgerIcon.classList.toggle('hidden');
    closeIcon.classList.toggle('hidden');
  }

  menuBtn.addEventListener('click', toggleMenu);

  // Automatically secure smooth closure if a user clicks an inner menu link
  const mobileLinks = mobileMenu.querySelectorAll('a');
  mobileLinks.forEach(link => {
    link.addEventListener('click', () => {
      if (menuBtn.getAttribute('aria-expanded') === 'true') {
        toggleMenu();
      }
    });
  });
</script>