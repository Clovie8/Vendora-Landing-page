---
// src/components/HowItWorks.astro
---

<section id="how-it-works" class="py-24 bg-slate-50 sm:py-32 border-y border-slate-200">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">From zero to selling in minutes</h2>
      <p class="mt-6 text-lg leading-8 text-slate-600">No lengthy onboarding or complex installations. Vendora is built to get out of your way so you can focus on your customers.</p>
    </div>

    <div class="mx-auto mt-16 max-w-5xl">
      <div class="grid grid-cols-1 gap-12 md:grid-cols-3 md:gap-8 relative">
        
        <!-- Connecting Line for Desktop -->
        <div class="hidden md:block absolute top-12 left-1/6 right-1/6 h-0.5 bg-slate-200 z-0"></div>

        <!-- Step 1 -->
        <div class="relative z-10 flex flex-col items-center text-center">
          <div class="flex h-24 w-24 items-center justify-center rounded-full bg-white shadow-md ring-1 ring-slate-100 mb-6 text-3xl font-bold text-[#0B2B5E]">1</div>
          <h3 class="text-xl font-semibold text-slate-900 mb-2">Register Your Business</h3>
          <p class="text-slate-600">Sign up online and create your account. Input your business details and configure your tax/VAT settings instantly.</p>
        </div>

        <!-- Step 2 -->
        <div class="relative z-10 flex flex-col items-center text-center">
          <div class="flex h-24 w-24 items-center justify-center rounded-full bg-white shadow-md ring-1 ring-slate-100 mb-6 text-3xl font-bold text-[#0B2B5E]">2</div>
          <h3 class="text-xl font-semibold text-slate-900 mb-2">Setup Inventory</h3>
          <p class="text-slate-600">Bulk import your products via CSV or add them manually. Set your stock levels, categories, and pricing rules.</p>
        </div>

        <!-- Step 3 -->
        <div class="relative z-10 flex flex-col items-center text-center">
          <div class="flex h-24 w-24 items-center justify-center rounded-full bg-emerald-500 shadow-md ring-4 ring-emerald-50 mb-6 text-3xl font-bold text-white">3</div>
          <h3 class="text-xl font-semibold text-slate-900 mb-2">Start Selling</h3>
          <p class="text-slate-600">Open the POS terminal on any tablet, PC, or phone and start processing orders immediately.</p>
        </div>

      </div>
    </div>
  </div>
</section>