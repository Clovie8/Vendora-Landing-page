---
// src/components/Footer.astro
const currentYear = new Date().getFullYear();
---

<footer class="bg-slate-950 border-t border-white/10" aria-labelledby="footer-heading">
  <h2 id="footer-heading" class="sr-only">Footer</h2>
  <div class="mx-auto max-w-7xl px-6 pb-8 pt-16 sm:pt-24 lg:px-8 lg:pt-32">
    <div class="xl:grid xl:grid-cols-3 xl:gap-8">
      
      <div class="space-y-8">
        <a href="/" class="flex items-center gap-2 text-white">
          <img class="h-14 w-auto" src="./Vendora-logo.png" alt="Vendora Logo"/>
          <span class="text-xl font-bold tracking-tight">Vendora</span>
        </a>
        <p class="text-sm leading-6 text-slate-400">
          The ultimate cloud-based POS and Inventory system engineered to help you scale.
        </p>
      </div>
      
      <div class="mt-16 grid grid-cols-2 gap-8 xl:col-span-2 xl:mt-0">
        <div class="md:grid md:grid-cols-2 md:gap-8">
          <div>
            <h3 class="text-sm font-semibold leading-6 text-white">Product</h3>
            <ul role="list" class="mt-6 space-y-4">
              <li><a href="/#features" class="text-sm leading-6 text-slate-400 hover:text-white transition-colors">Features</a></li>
              <li><a href="/#pricing" class="text-sm leading-6 text-slate-400 hover:text-white transition-colors">Pricing</a></li>
              <li><a href="https://dashboard.vendorapos.app/user-guide" target="_blank" class="text-sm leading-6 text-slate-400 hover:text-white transition-colors">Hardware Integration</a></li>
            </ul>
          </div>
          <div class="mt-10 md:mt-0">
            <h3 class="text-sm font-semibold leading-6 text-white">Support</h3>
            <ul role="list" class="mt-6 space-y-4">
              <li><a href="https://dashboard.vendorapos.app/user-guide" target="_blank" class="text-sm leading-6 text-slate-400 hover:text-white transition-colors">Documentation</a></li>
              <!-- <li><a href="#" class="text-sm leading-6 text-slate-400 hover:text-white transition-colors">API Reference</a></li> -->
              <li><a href="/contact" class="text-sm leading-6 text-slate-400 hover:text-white transition-colors">Contact Us</a></li>
            </ul>
          </div>
        </div>
        <div class="md:grid md:grid-cols-2 md:gap-8">
          <div>
            <h3 class="text-sm font-semibold leading-6 text-white">Company</h3>
            <ul role="list" class="mt-6 space-y-4">
              <li><a href="/about" class="text-sm leading-6 text-slate-400 hover:text-white transition-colors">About</a></li>
              <li><a href="#" class="text-sm leading-6 text-slate-400 hover:text-white transition-colors">Blog</a></li>
            </ul>
          </div>
          <div class="mt-10 md:mt-0">
            <h3 class="text-sm font-semibold leading-6 text-white">Legal</h3>
            <ul role="list" class="mt-6 space-y-4">
              <li><a href="/privacy" class="text-sm leading-6 text-slate-400 hover:text-white transition-colors">Privacy Policy</a></li>
              <li><a href="/terms" class="text-sm leading-6 text-slate-400 hover:text-white transition-colors">Terms of Service</a></li>
            </ul>
          </div>
        </div>
      </div>
    </div>
    
    <div class="mt-16 border-t border-white/10 pt-8 sm:mt-20 lg:mt-24">
      <p class="text-xs leading-5 text-slate-400">&copy; {currentYear} Vendora Inc. All rights reserved.</p>
    </div>
  </div>
</footer>