---
// src/components/Hero.astro
import dashboardImage from '../assets/Dashboard.png';
---

<section class="relative bg-[#0B2B5E] pt-20 pb-16 sm:pt-28 lg:pt-36">
  
  <div class="absolute inset-0 z-0 overflow-hidden pointer-events-none" aria-hidden="true">
    <img 
      src="https://images.unsplash.com/photo-1604719312566-8912e9227c6a?auto=format&fit=crop&w=2000&q=80" 
      alt="Modern Enterprise Logistics Hub" 
      class="w-full h-full object-cover object-center scale-105 filter blur-[1px]"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-[#0B2B5E]/85 via-[#0B2B5E]/90 to-[#0B2B5E]/95 mix-blend-multiply"></div>
    
    <div class="absolute -top-24 -right-24 w-[30rem] h-[30rem] bg-emerald-500/20 rounded-full blur-[120px]"></div>
    <div class="absolute bottom-0 left-10 w-[20rem] h-[20rem] bg-blue-400/10 rounded-full blur-[100px]"></div>
  </div>

  <div class="relative z-10 mx-auto max-w-10xl px-4 sm:px-6 lg:px-8 text-center pt-8 sm:pt-12">
    
    <!-- <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-white/5 border border-white/10 text-emerald-400 text-xs font-bold uppercase tracking-wide mb-8 shadow-sm backdrop-blur-md">
      <span class="relative flex w-2 h-2">
        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
        <span class="relative inline-flex rounded-full w-2 h-2 bg-emerald-500"></span>
      </span>
      Vendora 2.0 is Live
    </div> -->

    <h1 class="text-3xl sm:text-4xl lg:text-7xl font-extrabold text-white tracking-tight mb-6 leading-[1.1] drop-shadow-sm">
      Streamline Your Sales. <br class="hidden sm:block"/>
      <span class="text-transparent bg-clip-text bg-gradient-to-r from-emerald-400 to-emerald-200">
        Scale Your Business.
      </span>
    </h1>
    
    <p class="max-w-2xl mx-auto text-lg sm:text-xl text-slate-200 mb-10 leading-relaxed font-medium drop-shadow-sm">
      The all-in-one, cloud-based POS and Enterprise Resource Planning system built for high-growth retail and wholesale stores.
    </p>

    <div class="flex flex-col sm:flex-row justify-center items-center gap-4 mb-20 lg:mb-24 relative z-30">
      <a 
        href="https://dashboard.vendorapos.app/register" 
        target="_blank"
        class="w-full sm:w-auto flex justify-center items-center bg-emerald-500 hover:bg-emerald-400 text-white text-base font-semibold py-3 px-6 rounded-xl shadow-[0_0_40px_-10px_rgba(16,185,129,0.5)] transition-all hover:-translate-y-0.5 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-500"
      >
        Start 14-Day Free Trial
      </a>
      <!-- <a 
        href="#demo" 
        class="w-full sm:w-auto flex justify-center items-center bg-white/5 border border-white/20 hover:border-white/40 hover:bg-white/10 text-white text-base font-semibold py-4 px-8 rounded-xl transition-all focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white"
      >
        View Demo
      </a> -->
    </div>

  </div>

  <div class="relative z-20 max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 -mb-32 sm:-mb-48 lg:-mb-64">
    <div class="relative rounded-2xl bg-slate-900/40 p-2 sm:p-4 ring-1 ring-white/10 shadow-2xl backdrop-blur-md group hover:ring-white/20 transition-all duration-500">
      
      <div class="flex items-center gap-2 px-4 pb-3 pt-2">
        <div class="w-3 h-3 rounded-full bg-[#FF5F56] border border-[#E0443E]"></div>
        <div class="w-3 h-3 rounded-full bg-[#FFBD2E] border border-[#DEA123]"></div>
        <div class="w-3 h-3 rounded-full bg-[#27C93F] border border-[#1AAB29]"></div>
      </div>
      
      <div class="w-full aspect-video sm:aspect-[16/9] bg-slate-950 rounded-lg sm:rounded-xl overflow-hidden relative ring-1 ring-inset ring-white/5">
        
        <div class="absolute inset-0 flex items-center justify-center text-slate-500 font-medium z-0 px-4 text-center">
		  Loading Dashboard...
        </div>

        <img 
          src={dashboardImage.src}
          alt="Vendora SaaS Dashboard Interface" 
          class="absolute inset-0 w-full h-full object-cover object-top opacity-90 group-hover:opacity-100 transition-opacity duration-500 z-10"
        />
        
        <div class="absolute inset-0 shadow-[inset_0_0_0_1px_rgba(255,255,255,0.05)] z-20 pointer-events-none rounded-lg sm:rounded-xl"></div>
      </div>

    </div>
  </div>

</section>