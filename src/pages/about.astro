---
// src/pages/about.astro
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="About Us | Vendora Enterprise POS & ERP">
  <Navbar />

  <main class="overflow-x-hidden">
    <section class="relative bg-[#0B2B5E] pt-24 pb-28 lg:pt-32 lg:pb-40">
      <div class="absolute inset-0 z-0 pointer-events-none overflow-hidden" aria-hidden="true">
        <div class="absolute -top-40 -right-40 w-[40rem] h-[40rem] bg-emerald-500/10 rounded-full blur-[140px]"></div>
        <div class="absolute bottom-0 left-20 w-[30rem] h-[30rem] bg-blue-400/10 rounded-full blur-[120px]"></div>
      </div>

      <div class="relative z-10 max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-white tracking-tight mb-6 leading-[1.15]">
          Empowering businesses with <br class="hidden sm:block"/>
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-emerald-400 to-emerald-200">
            enterprise-grade tools.
          </span>
        </h1>
        <p class="max-w-3xl mx-auto text-lg sm:text-xl text-slate-300 leading-relaxed font-medium">
          We are building the operating system for modern retail, wholesale, and service businesses.
        </p>
      </div>
    </section>

    <section class="bg-white py-20 sm:py-28 lg:py-32">
      <div class="max-w-3xl mx-auto px-6 lg:px-8">
        <div class="text-center mb-12">
          <h2 class="text-base font-semibold leading-7 text-emerald-600 uppercase tracking-wider">Our Story</h2>
          <p class="mt-2 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">Why We Built Vendora</p>
        </div>
        
        <div class="prose prose-lg text-slate-600 space-y-8 leading-relaxed text-base sm:text-lg">
          <p>
            For too long, businesses have been forced to rely on fragmented systems. You had one software for sales, a spreadsheet for inventory, and a notebook for debts. This fragmentation caused lost revenue, operational bottlenecks, and endless frustration.
          </p>
          <p>
            We built Vendora to fix this. Designed and developed with a deep understanding of local and global commerce, Vendora brings POS, inventory management, CRM, and accounting into one unified, lightning-fast platform.
          </p>
        </div>
      </div>
    </section>

    <section class="bg-slate-50 py-20 sm:py-28 lg:py-32 border-y border-slate-100">
      <div class="mx-auto max-w-7xl px-6 lg:px-8">
        <div class="mx-auto max-w-2xl lg:text-center mb-16 sm:mb-20">
          <h2 class="text-base font-semibold leading-7 text-emerald-600 uppercase tracking-wider">Core Pillars</h2>
          <p class="mt-2 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">The Values That Drive Us</p>
        </div>

        <div class="mx-auto max-w-2xl lg:max-w-none">
          <dl class="grid max-w-xl grid-cols-1 gap-x-8 gap-y-12 lg:max-w-none lg:grid-cols-4 sm:grid-cols-2">
            
            <div class="flex flex-col bg-white p-8 rounded-2xl shadow-sm ring-1 ring-slate-200/60 hover:shadow-md transition-all duration-300">
              <dt class="text-base font-bold leading-7 text-slate-900 flex flex-col gap-y-4">
                <div class="h-11 w-11 flex items-center justify-center rounded-xl bg-emerald-600/10">
                  <svg class="w-6 h-6 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                </div>
                Reliability
              </dt>
              <dd class="mt-3 text-base leading-7 text-slate-600 flex-auto">
                Your business never sleeps, and neither does our system. We guarantee 99.9% uptime.
              </dd>
            </div>

            <div class="flex flex-col bg-white p-8 rounded-2xl shadow-sm ring-1 ring-slate-200/60 hover:shadow-md transition-all duration-300">
              <dt class="text-base font-bold leading-7 text-slate-900 flex flex-col gap-y-4">
                <div class="h-11 w-11 flex items-center justify-center rounded-xl bg-emerald-600/10">
                  <svg class="w-6 h-6 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z" />
                  </svg>
                </div>
                Security
              </dt>
              <dd class="mt-3 text-base leading-7 text-slate-600 flex-auto">
                Bank-level encryption protects your financial data, customer records, and inventory logs.
              </dd>
            </div>

            <div class="flex flex-col bg-white p-8 rounded-2xl shadow-sm ring-1 ring-slate-200/60 hover:shadow-md transition-all duration-300">
              <dt class="text-base font-bold leading-7 text-slate-900 flex flex-col gap-y-4">
                <div class="h-11 w-11 flex items-center justify-center rounded-xl bg-emerald-600/10">
                  <svg class="w-6 h-6 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" />
                  </svg>
                </div>
                Innovation
              </dt>
              <dd class="mt-3 text-base leading-7 text-slate-600 flex-auto">
                We constantly ship new features based on real feedback from business owners.
              </dd>
            </div>

            <div class="flex flex-col bg-white p-8 rounded-2xl shadow-sm ring-1 ring-slate-200/60 hover:shadow-md transition-all duration-300">
              <dt class="text-base font-bold leading-7 text-slate-900 flex flex-col gap-y-4">
                <div class="h-11 w-11 flex items-center justify-center rounded-xl bg-emerald-600/10">
                  <svg class="w-6 h-6 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z" />
                  </svg>
                </div>
                Customer First
              </dt>
              <dd class="mt-3 text-base leading-7 text-slate-600 flex-auto">
                When you succeed, we succeed. Our support team is treated as an extension of your own staff.
              </dd>
            </div>

          </dl>
        </div>
      </div>
    </section>

    <section class="relative bg-[#0B2B5E] py-24 sm:py-32 overflow-hidden">
      <div class="absolute inset-0 z-0 pointer-events-none overflow-hidden" aria-hidden="true">
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[50rem] h-[50rem] bg-emerald-500/10 rounded-full blur-[130px]"></div>
      </div>

      <div class="relative z-10 max-w-4xl mx-auto px-6 text-center">
        <h2 class="text-3xl font-extrabold tracking-tight text-white sm:text-4xl">
          Ready to transform your business?
        </h2>
        <p class="mx-auto mt-6 max-w-xl text-lg leading-8 text-slate-300">
          Join the businesses scaling their operations with Vendora today.
        </p>
        
        <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
          <a 
            href="https://dashboard.vendorapos.app/register" 
            target="_blank"
            class="w-full sm:w-auto bg-emerald-600 hover:bg-emerald-500 text-white text-base font-bold py-4 px-8 rounded-xl shadow-lg shadow-emerald-600/20 transition-all hover:-translate-y-0.5 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-600"
          >
            Start Free Trial
          </a>
          <a 
            href="/contact" 
            class="w-full sm:w-auto bg-transparent border-2 border-slate-400/40 hover:border-white text-white text-base font-bold py-4 px-8 rounded-xl transition-all hover:bg-white/5 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white"
          >
            Contact Sales
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>