---
// src/pages/contact.astro
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Contact Us | Vendora Enterprise POS">
  <Navbar />

  <div 
    id="toast-notification" 
    class="fixed top-6 right-6 z-50 flex items-center gap-x-3 rounded-xl p-4 shadow-xl ring-1 transform transition-all duration-300 translate-x-full opacity-0 pointer-events-none max-w-sm w-full bg-white"
  >
    <div id="toast-icon-success" class="hidden text-emerald-600 bg-emerald-100 p-2 rounded-lg">
      <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" />
      </svg>
    </div>
    <div id="toast-icon-error" class="hidden text-red-600 bg-red-100 p-2 rounded-lg">
      <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.28 7.22a.75.75 0 00-1.06 1.06L8.94 10l-1.72 1.72a.75.75 0 101.06 1.06L10 11.06l1.72 1.72a.75.75 0 101.06-1.06L11.06 10l1.72-1.72a.75.75 0 10-1.06-1.06L10 8.94 8.28 7.22z" clip-rule="evenodd" />
      </svg>
    </div>
    <div class="flex-1">
      <p id="toast-message" class="text-sm font-semibold text-slate-900">Notification message here</p>
    </div>
  </div>

  <main>
    <section class="relative bg-[#0B2B5E] pt-24 pb-48 lg:pt-32 lg:pb-64 overflow-hidden">
      <div class="absolute inset-0 z-0 pointer-events-none" aria-hidden="true">
        <div class="absolute -top-24 -right-24 w-[30rem] h-[30rem] bg-emerald-500/10 rounded-full blur-[100px]"></div>
        <div class="absolute bottom-0 left-10 w-[20rem] h-[20rem] bg-blue-400/10 rounded-full blur-[80px]"></div>
      </div>

      <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h1 class="text-4xl sm:text-5xl font-extrabold text-white tracking-tight mb-6">
          Get in Touch
        </h1>
        <p class="max-w-2xl mx-auto text-lg sm:text-xl text-slate-300 leading-relaxed font-medium">
          Whether you have a question about features, trials, pricing, or need technical support, our team is ready to help.
        </p>
      </div>
    </section>

    <section class="relative z-20 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 -mt-32 lg:-mt-48 mb-24">
        
        <div class="bg-white rounded-3xl shadow-2xl ring-1 ring-slate-200 overflow-hidden lg:flex">
          
          <div class="p-8 sm:p-10 lg:w-3/5 lg:p-14">
            <form id="contact-form" action="https://api.web3forms.com/submit" method="POST" class="space-y-6">
              
              <input type="hidden" name="access_key" value="5d74a7dc-7a97-4792-8e13-b980d28f7e18">
              <input type="checkbox" name="botcheck" class="hidden" style="display: none;">
              <input type="hidden" name="from_name" value="Vendora SaaS Contact Form">

              <div class="grid grid-cols-1 gap-x-8 gap-y-6 sm:grid-cols-2">
                <div>
                  <label for="first-name" class="block text-sm font-semibold leading-6 text-slate-900">First Name</label>
                  <div class="mt-2.5">
                    <input type="text" required name="first-name" id="first-name" autocomplete="given-name" class="block w-full rounded-md border-0 px-3.5 py-2 text-slate-900 shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-600 sm:text-sm sm:leading-6 transition-all">
                  </div>
                </div>
                <div>
                  <label for="last-name" class="block text-sm font-semibold leading-6 text-slate-900">Last Name</label>
                  <div class="mt-2.5">
                    <input type="text" required name="last-name" id="last-name" autocomplete="family-name" class="block w-full rounded-md border-0 px-3.5 py-2 text-slate-900 shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-600 sm:text-sm sm:leading-6 transition-all">
                  </div>
                </div>
                <div class="sm:col-span-2">
                  <label for="email" class="block text-sm font-semibold leading-6 text-slate-900">Email Address</label>
                  <div class="mt-2.5">
                    <input type="email" required name="email" id="email" autocomplete="email" class="block w-full rounded-md border-0 px-3.5 py-2 text-slate-900 shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-600 sm:text-sm sm:leading-6 transition-all">
                  </div>
                </div>
                <div class="sm:col-span-2">
                  <label for="subject" class="block text-sm font-semibold leading-6 text-slate-900">Subject</label>
                  <div class="mt-2.5">
                    <select id="subject" name="subject" class="block w-full rounded-md border-0 px-3.5 py-2.5 text-slate-900 shadow-sm ring-1 ring-inset ring-slate-300 focus:ring-2 focus:ring-inset focus:ring-emerald-600 sm:text-sm sm:leading-6 bg-white transition-all">
                      <option>General Inquiry</option>
                      <option>Sales & Pricing</option>
                      <option>Technical Support</option>
                      <option>Partnership</option>
                    </select>
                  </div>
                </div>
                <div class="sm:col-span-2">
                  <label for="message" class="block text-sm font-semibold leading-6 text-slate-900">Message</label>
                  <div class="mt-2.5">
                    <textarea required name="message" id="message" rows="4" class="block w-full rounded-md border-0 px-3.5 py-2 text-slate-900 shadow-sm ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-inset focus:ring-emerald-600 sm:text-sm sm:leading-6 transition-all"></textarea>
                  </div>
                </div>
              </div>
              <div class="mt-8">
                <button 
                  type="submit" 
                  id="submit-btn" 
                  class="flex items-center justify-center w-full rounded-xl bg-emerald-600 px-3.5 py-3.5 text-center text-sm font-bold text-white shadow-sm hover:bg-emerald-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-600 disabled:opacity-75 disabled:cursor-not-allowed transition-all"
                >
                  <span id="btn-text">Send Message</span>
                  <span id="btn-spinner" class="hidden flex items-center justify-center gap-2">
                    <svg class="animate-spin h-5 w-5 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                      <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                      <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                    </svg>
                    Sending...
                  </span>
                </button>
              </div>
            </form>
          </div>

          <div class="bg-slate-50 p-8 sm:p-10 lg:w-2/5 lg:p-14 border-t lg:border-t-0 lg:border-l border-slate-200 flex flex-col justify-center">
            <h3 class="text-2xl font-bold tracking-tight text-slate-900">Let's start a conversation</h3>
            <p class="mt-4 text-base leading-7 text-slate-600">
              We're headquartered in Kigali, Rwanda, but our tools power businesses globally. Reach out to the department you need directly.
            </p>

            <dl class="mt-10 space-y-8 text-base leading-7 text-slate-600">
              <div class="flex gap-x-4">
                <dt class="flex-none">
                  <span class="sr-only">Headquarters</span>
                  <svg class="h-7 w-6 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
                  </svg>
                </dt>
                <dd>
                  <strong class="text-slate-900 font-semibold block mb-1">Headquarters</strong>
                  Kigali, Rwanda<br>
                  KG 123 Ave, Innovation Block
                </dd>
              </div>
              <div class="flex gap-x-4">
                <dt class="flex-none">
                  <span class="sr-only">Sales & Partnerships</span>
                  <svg class="h-7 w-6 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
                  </svg>
                </dt>
                <dd>
                  <strong class="text-slate-900 font-semibold block mb-1">Sales & Partnerships</strong>
                  <a class="hover:text-emerald-600 transition-colors" href="mailto:sales@vendora.com">sales@vendora.com</a><br>
                  <a class="hover:text-emerald-600 transition-colors" href="tel:+250788000000">+250 788 000 000</a>
                </dd>
              </div>
            </dl>
          </div>
          
        </div>
      </div>
    </section>

    <section class="bg-slate-50 py-24 sm:py-32 border-t border-slate-200">
      <div class="mx-auto max-w-7xl px-6 lg:px-8">
        
        <div class="mx-auto max-w-2xl lg:mx-0">
          <h2 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">Customer Support</h2>
          <p class="mt-6 text-lg leading-8 text-slate-600">
            Already using Vendora? We provide enterprise-grade support to ensure your operations never stop.
          </p>
        </div>

        <div class="mx-auto mt-16 grid max-w-2xl grid-cols-1 gap-8 sm:mt-20 lg:mx-0 lg:max-w-none lg:grid-cols-3">
          
          <div class="flex flex-col bg-white rounded-2xl shadow-sm ring-1 ring-slate-200 p-8 hover:shadow-md transition-shadow">
            <div class="h-10 w-10 flex items-center justify-center rounded-lg bg-emerald-600/10 mb-6">
              <svg class="w-6 h-6 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
              </svg>
            </div>
            <h3 class="text-lg font-semibold leading-8 text-slate-900">Documentation</h3>
            <p class="mt-4 flex-auto text-base leading-7 text-slate-600">
              Browse our detailed system guides, API documentation, and daily setup tutorials.
            </p>
            <p class="mt-6">
              <a href="#" class="text-sm font-semibold leading-6 text-emerald-600 hover:text-emerald-500 transition-colors">Visit Docs <span aria-hidden="true">→</span></a>
            </p>
          </div>

          <div class="flex flex-col bg-white rounded-2xl shadow-sm ring-1 ring-slate-200 p-8 hover:shadow-md transition-shadow">
            <div class="h-10 w-10 flex items-center justify-center rounded-lg bg-emerald-600/10 mb-6">
              <svg class="w-6 h-6 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17L17.25 21A2.652 2.652 0 0021 17.25l-5.83-5.83m0 0l5.66-5.66c.19-.19.26-.47.19-.72a2.65 2.65 0 00-1.88-1.88c-.25-.07-.53 0-.72.19l-5.66 5.66m0 0l-5.66-5.66a2.65 2.65 0 00-3.75 3.75l5.66 5.66m0 0l-5.66 5.66c-.19.19-.26.47-.19.72a2.65 2.65 0 001.88 1.88c.25.07.53 0 .72-.19l5.66-5.66" />
              </svg>
            </div>
            <h3 class="text-lg font-semibold leading-8 text-slate-900">Technical Support</h3>
            <p class="mt-4 flex-auto text-base leading-7 text-slate-600">
              Submit a ticket to our engineering team for complex issues or system bug reports.
            </p>
            <p class="mt-6">
              <a href="mailto:support@vendora.com" class="text-sm font-semibold leading-6 text-emerald-600 hover:text-emerald-500 transition-colors">support@vendora.com <span aria-hidden="true">→</span></a>
            </p>
          </div>

          <div class="flex flex-col bg-white rounded-2xl shadow-sm ring-2 ring-emerald-600/20 p-8 relative hover:shadow-md transition-shadow">
            <div class="absolute top-8 right-8">
              <span class="inline-flex items-center rounded-full bg-amber-100 px-2.5 py-0.5 text-xs font-semibold text-amber-800 ring-1 ring-inset ring-amber-600/20">
                Available on Enterprise
              </span>
            </div>
            <div class="h-10 w-10 flex items-center justify-center rounded-lg bg-emerald-600/10 mb-6">
              <svg class="w-6 h-6 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-2.896-1.596-5.48-4.18-7.076-7.076l1.293-.97c.362-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
              </svg>
            </div>
            <h3 class="text-lg font-semibold leading-8 text-slate-900">Priority SLA</h3>
            <p class="mt-4 flex-auto text-base leading-7 text-slate-600">
              Enterprise users get 24/7 dedicated account manager access via WhatsApp and direct call.
            </p>
            <p class="mt-6">
              <a href="#" class="text-sm font-semibold leading-6 text-slate-900 hover:text-emerald-600 transition-colors">Upgrade Plan <span aria-hidden="true">→</span></a>
            </p>
          </div>

        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<script is:inline>
  const form = document.getElementById('contact-form');
  const submitBtn = document.getElementById('submit-btn');
  const btnText = document.getElementById('btn-text');
  const btnSpinner = document.getElementById('btn-spinner');
  
  const toast = document.getElementById('toast-notification');
  const toastMessage = document.getElementById('toast-message');
  const toastSuccessIcon = document.getElementById('toast-icon-success');
  const toastErrorIcon = document.getElementById('toast-icon-error');

  form.addEventListener('submit', function(e) {
    e.preventDefault();
    
    // 1. Set loading UI states on Button
    submitBtn.disabled = true;
    btnText.classList.add('hidden');
    btnSpinner.classList.remove('hidden');

    // 2. Prep form data payload
    const formData = new FormData(form);
    const jsonPayload = JSON.stringify(Object.fromEntries(formData));

    // 3. Dispatch to Web3Forms API
    fetch('https://api.web3forms.com/submit', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'Accept': 'application/json'
      },
      body: jsonPayload
    })
    .then(async (response) => {
      let result = await response.json();
      if (response.status === 200) {
        // Success Configuration
        toastMessage.textContent = "Message sent successfully!";
        toast.className = "fixed top-6 right-6 z-50 flex items-center gap-x-3 rounded-xl p-4 shadow-xl ring-1 max-w-sm w-full bg-emerald-50 ring-emerald-500/20 text-emerald-900 translate-x-0 opacity-100 pointer-events-auto transition-all duration-300";
        toastErrorIcon.classList.add('hidden');
        toastSuccessIcon.classList.remove('hidden');
        form.reset();
      } else {
        // Validation/Key Failure Configuration
        toastMessage.textContent = result.message || "Failed to submit.";
        toast.className = "fixed top-6 right-6 z-50 flex items-center gap-x-3 rounded-xl p-4 shadow-xl ring-1 max-w-sm w-full bg-red-50 ring-red-500/20 text-red-900 translate-x-0 opacity-100 pointer-events-auto transition-all duration-300";
        toastSuccessIcon.classList.add('hidden');
        toastErrorIcon.classList.remove('hidden');
      }
    })
    .catch((error) => {
      // Network Level Error
      toastMessage.textContent = "Network error. Please try again later.";
      toast.className = "fixed top-6 right-6 z-50 flex items-center gap-x-3 rounded-xl p-4 shadow-xl ring-1 max-w-sm w-full bg-red-50 ring-red-500/20 text-red-900 translate-x-0 opacity-100 pointer-events-auto transition-all duration-300";
      toastSuccessIcon.classList.add('hidden');
      toastErrorIcon.classList.remove('hidden');
    })
    .finally(() => {
      // 4. Tear down loading UI states on Button
      submitBtn.disabled = false;
      btnText.classList.remove('hidden');
      btnSpinner.classList.add('hidden');

      // 5. Clear Notification banner automatically after 4 seconds
      setTimeout(() => {
        toast.classList.remove('translate-x-0', 'opacity-100', 'pointer-events-auto');
        toast.classList.add('translate-x-full', 'opacity-0', 'pointer-events-none');
      }, 4000);
    });
  });
</script>